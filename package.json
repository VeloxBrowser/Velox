{
  "name": "velox-browser",
  "version": "1.0.1",
  "description": "Blazing fast, privacy-first browser with built-in ad blocking and proxy protection",
  "repository": {
    "type": "git",
    "url": "https://github.com/VeloxBrowser/Velox_Source"
  },
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.10.1",
    "cross-fetch": "^4.0.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.velox.browser",
    "productName": "Velox Browser",
    "publish": [
      {
        "provider": "github",
        "owner": "VeloxBrowser",
        "repo": "Velox_Source"
      }
    ],
    "extraResources": [
      {
        "from": "assets/tor",
        "to": "tor",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}